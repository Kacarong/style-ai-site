# Copy to .env and fill in values.

# Must match server/.env(.local) SHARED_SECRET.
# NEVER share this with the browser.
SHARED_SECRET=dev-secret-change-me

# Where to store image bytes + sidecar JSON files.
STORAGE_DIR=./storage

# Base URL embedded in signed image URLs. The site proxies image requests
# through Next.js (/api/image/...) so the browser never hits this URL directly,
# but it's still stored verbatim in SQLite. Any value with the shape
# "<scheme>://<host>:<port>" works; the proxy only extracts <id> and ?t=.
STORAGE_PUBLIC_BASE_URL=http://127.0.0.1:8000

# Read token byte length (entropy = N*8 bits).
READ_TOKEN_BYTES=32

# Provider: mock | fashn_vton_v15 | fal_kling
PROVIDER=mock

# fal.ai key (only used when PROVIDER=fal_kling)
FAL_KEY=

# ---- FASHN VTON v1.5 (only used when PROVIDER=fashn_vton_v15) ----
# Path to the weights directory created by `download_weights.py`. Required.
# Example (Windows): FASHN_WEIGHTS_DIR=C:\dev\fashn-vton-1.5\weights
FASHN_WEIGHTS_DIR=

# Inference settings (upstream defaults). Higher num_timesteps = better quality,
# slower. guidance_scale controls how strongly the garment is forced onto the
# person. Fixed seed makes results reproducible.
FASHN_NUM_TIMESTEPS=50
FASHN_GUIDANCE_SCALE=2.5
FASHN_SEED=42

# segmentation_free=true skips the body-part segmentation step. Faster but
# usually worse quality. Leave false unless you know you want it.
FASHN_SEGMENTATION_FREE=false
