# Copy to .env.local (dev) or .env (prod) and fill in values.

# Shared secret for server <-> inference Bearer auth.
# Dev: any string works. Prod: generate with `openssl rand -base64 48`.
# NEVER expose this to the browser. NEVER prefix with NEXT_PUBLIC_.
SHARED_SECRET=dev-secret-change-me

# Inference server base URL.
# Local dev: http://localhost:8000
# Prod: http://<your-PC-tailnet-ip>:8000
INFERENCE_BASE_URL=http://localhost:8000

# SQLite database file (relative to server/).
DATABASE_PATH=./data.sqlite

# Optional fal.ai fallback (Kling Kolors VTON v1.5).
# Leave empty in local dev.
FAL_KEY=
