# Copy to .env and fill in values.

# Must match server/.env(.local) SHARED_SECRET.
# NEVER share this with the browser.
SHARED_SECRET=dev-secret-change-me

# Where to store image bytes + sidecar JSON files.
STORAGE_DIR=./storage

# Base URL that the browser will use to fetch images.
# Local dev: http://localhost:8000
# Prod: http://<your-PC-tailnet-ip>:8000
STORAGE_PUBLIC_BASE_URL=http://localhost:8000

# Read token byte length (entropy = N*8 bits).
READ_TOKEN_BYTES=32

# Provider: mock | fashn_vton_v15 | fal_kling
PROVIDER=mock

# fal.ai key (only used when PROVIDER=fal_kling)
FAL_KEY=
